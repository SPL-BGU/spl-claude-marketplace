# cluster-ops.env — copy to cluster-ops.env (same dir as SKILL.md) and fill in.
# The scripts source this file if present. See SETUP.md for the full table.

# --- required ---
REMOTE_USER=               # your SSH user on the cluster (e.g. alice)
REMOTE_HOST=slurm.bgu.ac.il
REPO_REMOTE=               # repo directory name under $HOME on the remote (e.g. my-project)

# --- optional (sensible defaults shown; uncomment to override) ---
# REMOTE_RESULTS=~/$REPO_REMOTE/results
# REMOTE_LOG_DIR=~/$REPO_REMOTE/logs
# REMOTE_RESULTS_GLOBS=slurm_*           # comma-separated globs for sync.sh
# LOCAL_RESULTS_DIR=                     # default: <repo>/results
# GPU_PARTITIONS=                        # comma-separated partitions for preflight.sh capacity check
# JOB_NAME_PREFIX=                       # default --name-prefix for postmortem.sh
# NICE_VALUE=500                         # deprioritize-Nice for prioritize.sh
# HAS_SRES=0                             # set 1 if your cluster has an sres-style utilization tool
# STATE_FILE=~/.cache/cluster-ops-status.json
